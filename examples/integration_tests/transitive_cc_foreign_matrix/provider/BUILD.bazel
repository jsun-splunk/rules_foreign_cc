test_suite(
    name = "tests",
    tests = [
        ":libarchive_shared_zlib_dynamic",
        ":libarchive_shared_zlib_foreign_shared",
        ":libarchive_static_zlib_dynamic",
        ":libarchive_static_zlib_foreign_shared",
        ":libarchive_static_zlib_foreign_static",
        ":libarchive_static_zlib_static",
