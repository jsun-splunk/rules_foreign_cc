provider_semantic_parity_test(
    name = "libarchive_shared_zlib_dynamic",
    size = "small",
    actual = "@examples_libarchive//:libarchive_foreign_shared_zlib_dynamic",
    expected = "@examples_libarchive//:libarchive_dynamic_zlib_dynamic",
